{
  "name": "@suruj/scan-dog",
  "version": "1.1.0",
  "description": "Attack Surface Detector — discover endpoints, expose shadow APIs, map the attack surface",
  "type": "module",
  "bin": {
    "scandog": "dist/index.js",
    "zn": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "scan": "node dist/index.js scan",
    "dev": "tsx src/index.ts",
    "dev:scan": "tsx src/index.ts scan",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests --no-coverage 2>nul || echo 'No tests configured'"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "security", "sast", "endpoints", "attack-surface",
    "shadow-api", "api-security", "zero-proof", "zkp",
    "owasp", "devsecops"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "glob": "^11.0.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
